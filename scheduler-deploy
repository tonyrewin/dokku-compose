#!/usr/bin/env bash
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
source "$PLUGIN_CORE_AVAILABLE_PATH/common/property-functions"
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

# Simple check that docker compose v2 is available
fn-is-compose-installed() {
  local docker_bin="${DOCKER_BIN:-docker}"

  if ! command -v "$docker_bin" >/dev/null 2>&1; then
    return 1
  fi

  if ! "$docker_bin" compose version >/dev/null 2>&1; then
    return 1
  fi

  return 0
}

trigger-scheduler-compose-scheduler-deploy() {
  declare desc="scheduler-compose scheduler-deploy plugin trigger"
  declare trigger="scheduler-deploy"
  declare DOKKU_SCHEDULER="$1" APP="$2" IMAGE_TAG="$3" PROCESS_TYPE="$4"

  if [[ "$DOKKU_SCHEDULER" != "compose" ]]; then
    return
  fi

  verify_app_name "$APP"

  if ! fn-is-compose-installed; then
    dokku_log_fail "Docker Compose v2 plugin is not installed. Please install the docker compose plugin (\"docker compose\") to use the compose scheduler."
  fi

  if ! command -v jq >/dev/null 2>&1; then
    dokku_log_fail "The scheduler-compose plugin requires 'jq' to be installed on the Dokku host."
  fi

  # resolve compose file: prefer scheduler-compose:compose-path, fall back to builder-compose:compose-path,
  # then standard names in the app repo.
  local COMPOSE_PATH
  COMPOSE_PATH="$(fn-plugin-property-get "scheduler-compose" "$APP" "compose-path")"
  if [[ -z "$COMPOSE_PATH" ]]; then
    COMPOSE_PATH="$(fn-plugin-property-get "builder-compose" "$APP" "compose-path")"
  fi

  local APP_ROOT="$DOKKU_ROOT/$APP"
  local CANDIDATES=()
  if [[ -n "$COMPOSE_PATH" ]]; then
    CANDIDATES+=("$COMPOSE_PATH")
  fi
  CANDIDATES+=("docker-compose.yml" "docker-compose.yaml" "compose.yml" "compose.yaml")

  local COMPOSE_FILE=""
  local candidate
  for candidate in "${CANDIDATES[@]}"; do
    if [[ "$candidate" = /* ]]; then
      # absolute path
      if [[ -f "$candidate" ]]; then
        COMPOSE_FILE="$candidate"
        break
      fi
    else
      # path relative to app root
      if [[ -f "$APP_ROOT/$candidate" ]]; then
        COMPOSE_FILE="$APP_ROOT/$candidate"
        break
      fi
    fi
  done

  if [[ -z "$COMPOSE_FILE" ]]; then
    dokku_log_fail "No docker compose file found for app $APP in $APP_ROOT"
  fi

  local PROJECT_NAME
  PROJECT_NAME="$(fn-plugin-property-get "scheduler-compose" "$APP" "project-name")"
  [[ -z "$PROJECT_NAME" ]] && PROJECT_NAME="dokku-${APP}"
  local PROJECT_NETWORK="${PROJECT_NAME}_default"

  local COMPOSE_DIR
  COMPOSE_DIR="$(cd "$(dirname "$COMPOSE_FILE")" && pwd)"

  # generate normalized compose config as json
  local TMP_JSON
  TMP_JSON=$(mktemp "/tmp/dokku-${DOKKU_PID:-$$}-${FUNCNAME[0]}.XXXXXX")
  trap "rm -rf '$TMP_JSON' >/dev/null" RETURN INT TERM EXIT

  local docker_bin="${DOCKER_BIN:-docker}"
  if ! "$docker_bin" compose -p "$PROJECT_NAME" -f "$COMPOSE_FILE" config --format json >"$TMP_JSON"; then
    dokku_log_fail "Failed to parse compose file at $COMPOSE_FILE"
  fi

  # collect services and mark which are external (may map to already-running instances)
  # Columns: service_name, is_external, datastore_spec
  local SERVICE_LINES
  SERVICE_LINES=$(jq -r '
    (.services // {}) | to_entries[]
    # skip services that are meant to be handled by Dokku''s internal letsencrypt plugin
    | select(.key != "letsencrypt" and .key != "certbot")
    | select((.value.labels["com.dokku.letsencrypt"] // "false") != "true")
    | select((.value.labels["com.dokku.certbot"] // "false") != "true")
    | select((.value.labels["com.dokku.compose"] // "true") != "false")
    | [
        .key,
        ((.value.labels["com.dokku.external"] // "false") == "true"),
        (.value.labels["com.dokku.datastore"] // "")
      ]
    | @tsv
  ' "$TMP_JSON" 2>/dev/null || true)

  if [[ -z "$SERVICE_LINES" ]]; then
    dokku_log_fail "No runnable services found in compose file for app $APP"
  fi

  local SERVICES=()
  local EXTERNAL_EXISTING_SERVICES=()
  local svc_name is_external datastore_spec existing_id
  while IFS=$'\t' read -r svc_name is_external datastore_spec; do
    [[ -z "$svc_name" ]] && continue

    if [[ "$is_external" == "true" ]]; then
      # External service handling:
      # 1. If com.dokku.datastore=<type>:<name> указан, пробуем найти инстанс плагина Dokku
      #    (например dokku.postgres.<name> или dokku.redis.<name>).
      # 2. Если не нашли или лейбла нет, пробуем найти контейнер по имени сервиса.

      existing_id=""

      if [[ -n "$datastore_spec" ]]; then
        local ds_type ds_name ds_container_name
        ds_type="${datastore_spec%%:*}"
        ds_name="${datastore_spec#*:}"

        case "$ds_type" in
          postgres)
            ds_container_name="dokku.postgres.${ds_name}"
            ;;
          redis)
            ds_container_name="dokku.redis.${ds_name}"
            ;;
          *)
            ds_container_name=""
            ;;
        esac

        if [[ -n "$ds_container_name" ]]; then
          existing_id="$("$docker_bin" ps -q --filter "name=^${ds_container_name}$" 2>/dev/null || true)"
        fi
      fi

      # Fallback: ищем контейнер по имени сервиса (например, отдельная Dokku-аппа или произвольный контейнер)
      if [[ -z "$existing_id" ]]; then
        existing_id="$("$docker_bin" ps -q --filter "name=^${svc_name}$" 2>/dev/null || true)"
      fi

      if [[ -n "$existing_id" ]]; then
        # Храним пару service_name:container_id для последующего подключения к сети
        EXTERNAL_EXISTING_SERVICES+=("${svc_name}:${existing_id}")
        continue
      fi
    fi

    SERVICES+=("$svc_name")
  done <<<"$SERVICE_LINES"

  if [[ "${#SERVICES[@]}" -eq 0 ]]; then
    dokku_log_fail "No services scheduled to run for app $APP (after resolving external services)"
  fi

  dokku_log_info1 "Deploying $APP via docker compose scheduler (project: $PROJECT_NAME, services: ${SERVICES[*]})"

  pushd "$COMPOSE_DIR" >/dev/null
  if ! "$docker_bin" compose -p "$PROJECT_NAME" -f "$COMPOSE_FILE" up -d "${SERVICES[@]}"; then
    dokku_log_fail "docker compose up failed for app $APP"
  fi
  popd >/dev/null

  # Ensure existing external services are attached to the compose project network
  if [[ "${#EXTERNAL_EXISTING_SERVICES[@]}" -gt 0 ]]; then
    # Network will have been created by docker compose up; if not, try to create it.
    if ! "$docker_bin" network inspect "$PROJECT_NETWORK" >/dev/null 2>&1; then
      "$docker_bin" network create "$PROJECT_NETWORK" >/dev/null 2>&1 || true
    fi

    local ext_entry ext_svc
    for ext_entry in "${EXTERNAL_EXISTING_SERVICES[@]}"; do
      ext_svc="${ext_entry%%:*}"
      existing_id="${ext_entry#*:}"
      if [[ -n "$existing_id" ]]; then
        # Проверяем, не присоединён ли контейнер уже к нужной сети
        local already_attached=false
        if "$docker_bin" inspect "$existing_id" >/dev/null 2>&1; then
          if "$docker_bin" inspect "$existing_id" -f '{{json .NetworkSettings.Networks}}' 2>/dev/null \
            | jq -e --arg net "$PROJECT_NETWORK" 'has($net)' >/dev/null 2>&1; then
            already_attached=true
          fi
        fi

        if [[ "$already_attached" != "true" ]]; then
          "$docker_bin" network connect "$PROJECT_NETWORK" "$existing_id" >/dev/null 2>&1 || true
          dokku_log_info2 "Attached existing external service '$ext_svc' to network '$PROJECT_NETWORK'"
        fi
      fi
    done
  fi

  # We don't currently know the bound port/ip for the primary web service here,
  # so pass empty values as is done in other schedulers when that information
  # is not directly available.
  local port=""
  local ipaddr=""

  plugn trigger core-post-deploy "$APP" "$port" "$ipaddr" "$IMAGE_TAG"
  plugn trigger post-deploy "$APP" "$port" "$ipaddr" "$IMAGE_TAG"
}

trigger-scheduler-compose-scheduler-deploy "$@"


